# Google Calendar API (used by the Vue frontend)
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Enable the Google Calendar API in your Google Cloud project
VITE_GOOGLE_CALENDAR_API_KEY=your_api_key_here

# --- Newsletter script (scripts/generate-newsletter.js) ---

# Path to the Google Service Account JSON key file (used for Calendar read, Docs/Drive write via DWD)
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=/path/to/service-account-key.json

# Google Calendar ID (same calendar the frontend uses)
GOOGLE_CALENDAR_ID=ig7e0j6v8ub9q6kga256n77048@group.calendar.google.com

# Google Drive folder ID where newsletter docs are created
# Extract from the folder URL: drive.google.com/drive/folders/{FOLDER_ID}
GOOGLE_DRIVE_FOLDER_ID=

# PocketBase instance
POCKETBASE_URL=https://your-pocketbase-instance.com
POCKETBASE_ADMIN_EMAIL=admin@indyhackers.org
POCKETBASE_ADMIN_PASSWORD=

# Slack incoming webhook URL
# Create at: api.slack.com > Your Apps > Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
